# SaaS Engine
NEXT_PUBLIC_ENGINE_URL=https://saas-engine-production.up.railway.app
SAAS_ENGINE_API_KEY=sk_live_YOUR_KEY_HERE
SAAS_ENGINE_ORG_ID=YOUR_ORG_ID_HERE
SAAS_ENGINE_PROJECT_ID=YOUR_PROJECT_ID_HERE
NEXT_PUBLIC_ORG_ID=YOUR_ORG_ID_HERE
NEXT_PUBLIC_PROJECT_ID=YOUR_PROJECT_ID_HERE
NEXT_PUBLIC_API_KEY=sk_live_YOUR_KEY_HERE

# Anthropic (only needed when USE_LOCAL_LLM=false)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Local LLM
USE_LOCAL_LLM=true
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Stripe
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
STRIPE_PRO_PRICE_ID=price_YOUR_PRICE_ID_HERE

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
